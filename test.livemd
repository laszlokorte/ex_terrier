## CGA2

```elixir
alias Galixir.Algebras.CGA2

defmodule CGADraw do
  import CGA2

  def point?(p) do
    abs(dot(p, p)) < 1.0e-10 and
      coefficient(p, :ep) != 0 and
      coefficient(p, :em) != 0
  end

  def circle?(c) do
    grades(c) == [3]
  end

  def line?(l) do
    grades(l) == [3] and
      coefficient(l, :e12pm) == 0
  end

  def point_pair?(x) do
    grades(x) == [2]
  end

  def circle_parameters(c) do
    v = gp(c, inverse(pseudoscalar()))

    e1 = coefficient(v, :e1) || 0.0
    e2 = coefficient(v, :e2) || 0.0

    ep = coefficient(v, :ep) || 0.0
    em = coefficient(v, :em) || 0.0

    w = em - ep

    if abs(w) < 1.0e-10 do
      {:line,
       {
         e1,
         e2,
         (em + ep) / 2
       }}
    else
      x = e1 / w
      y = e2 / w

      k = (em + ep) / (2 * w)

      r =
        :math.sqrt(
          x * x +
            y * y -
            2 * k
        )

      {:circle, {{x, y}, r}}
    end
  end

  def split(o) do
    import Galixir.Algebras.CGA2

    ei = e_inf()
    eo = e_o()

    nix = wedge(o, ei)

    nix2 = scalar_part(inner(nix, nix))

    if abs(nix2) < 1.0e-12 do
      raise ArgumentError, "invalid point pair"
    end

    r2 =
      scalar_part(inner(o, o)) / nix2

    r = :math.sqrt(abs(r2))

    pos =
      o
      |> gp(inverse(nix))
      |> normalize_point()

    attitude =
      wedge(ei, eo)
      |> inner(nix)
      |> normalize()
      |> scale(r)

    kind =
      cond do
        r2 >= 0 ->
          :real

        true ->
          :imag
      end

    {
      kind,
      normalize_point(add(pos, attitude)),
      normalize_point(sub(pos, attitude))
    }
  end

  def normalize_point(p) do
    w =
      -scalar_part(inner(p, e_inf()))

    scale(p, 1 / w)
  end

  def classify(x) do
    cond do
      point?(x) ->
        {:point, point_coordinates(x)}

      circle?(x) ->
        {:circle, circle_parameters(x)}

      line?(x) ->
        {:line, line_parameters(x)}

      point_pair?(x) ->
        {kind, p1, p2} = split(x)

        {
          :point_pair,
          kind,
          {point_coordinates(p1), point_coordinates(p2)}
        }

      true ->
        {:unknown, x}
    end
  end

  def line_parameters(l) do
    {
      CGA2.coefficient(l, :e12p),
      CGA2.coefficient(l, :e12m),
      CGA2.coefficient(l, :e1pm)
    }
  end

  def to_svg(shapes) do
    """
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="-50 -50 100 100" width="100" height="40">

      #{for {color, s} <- shapes do
      classify(s) |> case do
        {:circle, {:circle, {{cx, cy}, r}}} -> """
          <circle
            cx="#{cx}"
            cy="#{-cy}"
            r="#{r}"
            fill="none"
            stroke="#{color}"
            stroke-width="1"/>
          """
        {:point, {cx, cy}} -> """
          <circle
            cx="#{cx}"
            cy="#{-cy}"
            r="1"
            fill="#{color}"
            stroke="none"
            stroke-width="1"/>
          """
        {:point_pair, :real, {{cx1, cy1}, {cx2, cy2}}} -> """
          <circle
            cx="#{cx1}"
            cy="#{-cy1}"
            r="1"
            fill="#{color}"
          stroke="none"
            stroke-width="1"/>
          <circle
            cx="#{cx2}"
            cy="#{-cy2}"
            r="1"
          stroke="none"
            fill="#{color}"
          fill-opacity="0.5"
            stroke-width="1"/>
          """
        {:point_pair, :imag, {{cx1, cy1}, {cx2, cy2}}} -> """
          <circle
            cx="#{cx1}"
            cy="#{-cy1}"
            r="1"
            stroke="#{color}"
          fill="none"
          stroke-dasharray="1 1"
            stroke-width="2"/>
          <circle
            cx="#{cx2}"
            cy="#{-cy2}"
            r="1"
            fill="none"
          stroke-dasharray="1 1"
            stroke="#{color}"
            stroke-width="2"/>
          """
        _ -> ""
      end
    end}

    </svg>
    <style>
    svg {
    display: block;
    width: 100%;
    height: auto;
    box-sizing: border-box;
    border: 1px solid red;
    }
    </style>
    """
  end

  def intersect(a, b) do
    undual(wedge(dual(a), dual(b)))
    wedge(gp(a, pseudoscalar()), gp(b, pseudoscalar())) |> gp(inverse(pseudoscalar()))
  end
end

p0 = CGA2.point(10, 4)
p1 = CGA2.point(10, 15)
p2 = CGA2.point(0, 10)

c1 = CGA2.circle(p0, 15)
c2 = CGA2.circle(p2, 10)
c3 = CGA2.circle(p1, 25)

p4 = CGA2.point(50, 8)
p5 = CGA2.point(43, 20)
p6 = CGA2.point(60, 10)

cc = CGA2.wedge(p4, p5) |> CGA2.wedge(p6)

Kino.HTML.new(
  CGADraw.to_svg([
    {:blue, c1},
    {:green, c2},
    {:green, p2},
    {:orange, c3},
    {:orange, p1},
    {:blue, p0},
    {:purple, p4},
    {:purple, p5},
    {:purple, p6},
    {:hotpink, cc},
    {:orange, CGADraw.intersect(c2, c3)},
    {:cyan, CGADraw.intersect(c1, c2)},
    {:cyan, CGADraw.intersect(c1, c3)}
    # {:red, CGA2.wedge(CGA2.point(10, 10), CGA2.point(10, -10))},
    # {:magenta, CGA2.point(40, 60)},
    # {:limegreen, CGA1.new(e12: -4, e1p: -19.5, e1m: -16.5, e2p: 23, e2m: 17, epm: -12)},
    # {:brown, CGA2.new(e12: 12, e1p: 19.5, e1m: 16.5, e2p: 9, e2m: 15, epm: 12)}
  ])
)
```

