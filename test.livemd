```elixir
defmodule Utils do
  import PGA3

  def align(from, to) do
    {motor, _q} =
      Enum.zip(from, to)
      |> Enum.reduce({new(scalar: 1), dual(new(scalar: 1))}, fn {p, q}, {m, q_acc} ->
        p_curr =
          join(q_acc, transform(m, p))

        p_curr = p_curr |> canonicalize()

        q_next =
          join(q_acc, q)

        q_next = q_next |> canonicalize()

        delta = gp(q_next, blade_inverse(p_curr))

        q_next =
          if scalar_part(delta) < 0 do
            negate(q_next)
          else
            q_next
          end

        delta = gp(q_next, blade_inverse(p_curr))

        step =
          add(new(scalar: 1), delta)
          |> normalize()

        m2 =
          gp(step, m)
          |> normalize()

        {m2, q_next}
      end)

    motor
  end

  def lcontract(a, b) do
    ga = grade(a)
    gb = grade(b)

    if ga > gb do
      PGA3.new()
    else
      PGA3.gp(a, b)
      |> PGA3.grade(gb - ga)
    end
  end

  def grade(%PGA3{} = mv) do
    case PGA3.grades(mv) do
      [g] ->
        g

      [] ->
        raise ArgumentError, "zero multivector has no grade"

      gs ->
        raise ArgumentError,
              "multivector has multiple grades: #{inspect(gs)}"
    end
  end

  def look_at(position, target, pole \\ ideal_point(0, 0, 1)) do
    IO.inspect(PGA3.grades(pole), label: "grades(pole)")

    align(
      [
        dual(new(e0: 1)),
        negate(dual(new(e3: 1))),
        dual(new(e2: 1))
      ],
      [
        position,
        target,
        pole
      ]
    )
  end
end
```

```elixir
line =
  PGA3.join(
    PGA3.point(1, 0, 0),
    PGA3.point(1, 0, -1)
  )

point = PGA3.point(1,0,0.5)
IO.inspect(line, label: "line")

plane =
  PGA3.join(
    line,
    PGA3.ideal_point(0, 0, 1)
  )

dl = PGA3.dual(line)
di = PGA3.dual(PGA3.ideal_point(0, 0, 1))

IO.inspect(dl, label: "dual(line)")
IO.inspect(di, label: "dual(ideal)")

w = PGA3.wedge(dl, di)

IO.inspect(w, label: "wedge")
IO.inspect(PGA3.grades(w), label: "wedge grades")
```

```elixir
IO.inspect(PGA3.line(
  PGA3.point(1,0,0),
  PGA3.point(1,0,-1)
))
```

```elixir
IO.inspect(
  PGA3.wedge(
    PGA3.point(1,0,0),
    PGA3.point(1,0,-1)
  ),
  label: "wedge(points)"
)
```

```elixir
IO.inspect(PGA3.join(line, point), label: "join")
IO.inspect(PGA3.zero?(PGA3.join(line, point)), label: "zero?")
IO.inspect(PGA3.contains?(line, point), label: "contains?")
```

```elixir
IO.inspect(PGA3.grades(line))
IO.inspect(PGA3.grades(point))

IO.inspect(PGA3.dual(line), label: "dual(line)")
IO.inspect(PGA3.dual(point), label: "dual(point)")

w = PGA3.wedge(PGA3.dual(line), PGA3.dual(point))

IO.inspect(w, label: "wedge")
IO.inspect(PGA3.grades(w), label: "wedge grades")

IO.inspect(PGA3.undual(w), label: "undual")
```

