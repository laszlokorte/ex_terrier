```elixir
eye = PGA3.point(1, 1, 1)
target = PGA3.point(0, 0, 0)
pole = PGA3.ideal_point(0, 0, 1)

camera = Utils.look_at(eye, target, pole)

trans = fn m, o ->
  PGA3.gp(PGA3.gp(m, o), PGA3.reverse(m))
end

camera
|> trans.(eye)
|> IO.inspect(label: "eye'")

t = PGA3.translator(-1, -1, -1)

t |> trans.(PGA3.point(0, 0, 0)) |> PGA3.point_coordinates()
```

```elixir
