```elixir
pyramid_base = [
  red: PGA3.point(1, 1, 0),
  red: PGA3.point(1, -1, 0),
  red: PGA3.point(-1, -1, 0),
  red: PGA3.point(-1, 1, 0),
  
  blue: PGA3.point(1, 0, 0),
  blue: PGA3.point(-1, 0, 0),
  blue: PGA3.point(0, -1, 0),
  blue: PGA3.point(0, 1, 0)
]

pyramid_tip = PGA3.point(0, 0, 3)

pyramid_points = [
 {:green, pyramid_tip} | pyramid_base
]
```

