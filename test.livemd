PGA3.transform(camera, PGA3.point(1, 2, 3)) |> PGA3.point_coordinates()
```

## CGA2

```elixir
alias Galixir.Algebras.CGA2

defmodule CGADraw do
  import CGA2

  def point?(p) do
    abs(dot(p, p)) < 1.0e-10 and
      coefficient(p, :ep) != 0 and
      coefficient(p, :em) != 0
  end

  def circle?(c) do
    grades(c) == [1] and
      coefficient(c, :ep) != 0 and
      coefficient(c, :em) != 0 and
      not point?(c)
  end

  def line?(l) do
    grades(l) == [3] and
      coefficient(l, :e12pm) == 0
  end

  def point_pair?(x) do
    grades(x) == [2]
  end

  def circle_parameters(c) do
    x = coefficient(c, :e1)
    y = coefficient(c, :e2)

    em = coefficient(c, :em)
    ep = coefficient(c, :ep)

    r2 =
      x * x +
        y * y -
        (em - ep)

    {{x, y}, :math.sqrt(r2)}
  end


  def project_grade(mv, wanted_grade) do
    Enum.reduce(0..dimension(), zero(), fn grade, acc ->
      if grade == wanted_grade do
        add(acc, grade(mv, grade))
      else
        acc
      end
    end)
  end

  def factor(pp) do
    e = e_inf()

    # line containing the pair
    line =
      wedge(pp, e)
      |> dual()

    # center of the point pair
    c =
      pp
      |> gp(reverse(e))
      |> project_grade(1)

    # squared distance
    s =
      scalar_part(gp(pp, reverse(pp)))

    d = :math.sqrt(abs(s))

    p1 =
      add(c, scale(d, line))
      |> normalize_point()

    p2 =
      sub(c, scale(d, line))
      |> normalize_point()

    {p1, p2}
  end

  @doc """
  Extracts the two Euclidean points from a point pair
  (e.g. the result of `intersect/2` on two circles).

  Returns `{:ok, {{x1, y1}, {x2, y2}}}` if the objects really
  intersect in two real points, or `{:error, :no_real_intersection}`
  if they don't (tangent gives two coincident points; disjoint
  circles give an imaginary pair).
  """
  def point_pair_coordinates(pp) do
    {p1, p2} = factor(pp)

    {
      point_coordinates(p1),
      point_coordinates(p2)
    }
  end

  def normalize_point(p) do
    p
  end

  def classify(x) do
    cond do
      point?(x) ->
        {:point, point_coordinates(x)}

      circle?(x) ->
        {:circle, circle_parameters(x)}

      line?(x) ->
        {:line, line_parameters(x)}

      point_pair?(x) ->
        {:point_pair, point_pair_coordinates(x)}

      true ->
        {:unknown, x}
    end
  end

  def line_parameters(l) do
    {
      CGA2.coefficient(l, :e12p),
      CGA2.coefficient(l, :e12m),
      CGA2.coefficient(l, :e1pm)
    }
  end

  def to_svg(shapes) do
    """
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="-500 -500 1000 1000" width="100" height="40">

      #{for {color, s} <- shapes do
      classify(s) |> case do
        {:circle, {{cx, cy}, r}} -> """
          <circle
            cx="#{cx}"
            cy="#{cy}"
            r="#{r}"
            fill="none"
            stroke="#{color}"
            stroke-width="1"/>
          """
        {:point, {cx, cy}} -> """
          <circle
            cx="#{cx}"
            cy="#{cy}"
            r="5"
            fill="#{color}"
            stroke="none"
            stroke-width="1"/>
          """
        {:point_pair, {{cx1, cy1}, {cx2, cy2}} = p} -> dbg(p)
          """
          <circle
            cx="#{cx1}"
            cy="#{cy1}"
            r="10"
            fill="#{color}"
            stroke="none"
            stroke-width="1"/>
          <circle
            cx="#{cx2}"
            cy="#{cy2}"
            r="10"
            fill="#{color}"
            stroke="none"
            stroke-width="1"/>
          """
        _ -> ""
      end
    end}

    </svg>
    <style>
    svg {
    display: block;
    width: 100%;
    height: auto;
    box-sizing: border-box;
    border: 1px solid red;
    }
    </style>
    """
  end

  def circle(x, y, r) do
    add(
      point(x, y),
      scale(
        -0.5 * r * r,
        e_inf()
      )
    )
  end

  def contains?(object, point) do
    abs(dot(object, point)) < 1.0e-10
  end

  def inside?(circle, point) do
    {{cx, cy}, r} = circle_parameters(circle)
    {x, y} = point_coordinates(point)

    dx = x - cx
    dy = y - cy

    dx * dx + dy * dy < r * r
  end

  def intersect(a, b) do
    wedge(a, b)
  end
end

p = CGA2.point(0, 200)

c =
  CGA2.circle(
    CGA2.point(0, 0),
    300
  )

c1 =
  CGA2.circle(
    CGA2.point(50, 30),
    100
  )

c2 =
  CGA2.circle(
    CGA2.point(150, 30),
    100
  )

Kino.HTML.new(
  CGADraw.to_svg([
    {:blue, c1},
    {:green, c2},
    {:red, CGA2.point(100, 30)},
    {:orange, c},
    {:magenta, CGA2.point(100, 30)},
    {if(CGADraw.inside?(c, p), do: "green", else: "red"), p},
    {:magenta, CGADraw.intersect(c1, c2)}
  ])
)
```

```elixir
CGADraw.circle_parameters(
  CGA2.circle(
    CGA2.point(50, 30),
    100
  )
)
```

```elixir
CGADraw.intersect(c1, c2)
```

```elixir
c1 =
  CGA2.circle(
    CGA2.point(50, 30),
    100
  )

c2 =
  CGA2.circle(
    CGA2.point(150, 30),
    100
  )

CGADraw.intersect(c1, c2)
|> CGADraw.point_pair_coordinates()
```

