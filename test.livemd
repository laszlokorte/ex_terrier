```elixir
defmodule Split2 do
  def split(%CGA2{} = b) do
    import Galixir.Algebras.CGA2
    b2 = scalar_part(inner(b, b))

    if b2 == 0 do
      raise ArgumentError, "cannot split null bivector"
    end

    b_bar =
      scale(b, 1 / :math.sqrt(abs(b2)))

    p =
      add(
        new(scalar: 1),
        b_bar
      )

    p_tilde =
      sub(
        new(scalar: 1),
        b_bar
      )

    v =
      inner(
        b,
        new(em: 1)
      )

    p1 =
      gp(p, v)

    p2 =
      gp(p_tilde, v)

    {
      p1,
      p2
    }
  end

  def normalize_point(p) do
    import Galixir.Algebras.CGA2
    w = scalar_part(inner(p, e_o()))
    scale(p, 1 / w)
  end
end

c1 =
  CGA2.circle(CGA2.point(10, 0), :math.sqrt(200))
  |> IO.inspect(label: "c1 = circle(point(10,0), sqrt(200))")

c2 =
  CGA2.circle(CGA2.point(-10, 0), :math.sqrt(200))
  |> IO.inspect(label: "c2 = circle(point(-10, 0), sqrt(200))")

CGA2.dual(c1) |> IO.inspect(label: "dual(c1)")
CGA2.dual(c2) |> IO.inspect(label: "dual(c2)")
CGA2.wedge(CGA2.dual(c1), CGA2.dual(c2)) |> IO.inspect(label: "wedge(dual(c1), dual(c2))")

CGA2.undual(CGA2.wedge(CGA2.dual(c1), CGA2.dual(c2)))
|> IO.inspect(label: "undual(wedge(dual(c1), dual(c2)))")

CGA2.dual(CGA2.wedge(CGA2.dual(c1), CGA2.dual(c2)))
|> IO.inspect(label: "dual(wedge(dual(c1), dual(c2)))")

expected_inter_p1 = CGA2.point(0, 10) |> IO.inspect(label: "expected p1 [p1 = point(0, 10)]")
expected_inter_p2 = CGA2.point(0, -10) |> IO.inspect(label: "expected p2 [p2 = point(0, -10)]")

expected_pair =
  CGA2.wedge(expected_inter_p1, expected_inter_p2)
  |> IO.inspect(label: "expected pair [wedge(p1, p2)]")

c1c2intersection =
  CGA2.meet(c1, c2)
  |> IO.inspect(label: "actual_pair [meet(c1, c2)]")

{i1, i2} =
  Split2.split(CGA2.scale(-1, c1c2intersection))
  |> IO.inspect(label: "(i1, i2) = split(-meet(c1, c2))")

{e1, e2} = Split2.split(expected_pair) |> IO.inspect(label: "(e1, e2) = split(wedge(p1, p2))")

CGA2.point_coordinates(i1) |> IO.inspect(label: "coords(i1)")
CGA2.point_coordinates(e1) |> IO.inspect(label: "coords(e1)")

CGA2.point_coordinates(i2) |> IO.inspect(label: "coords(i2)")
CGA2.point_coordinates(e2) |> IO.inspect(label: "coords(e2)")

Kino.nothing()
```

