alias Galixir.Algebras.PGA3

PGA3.point(1, 2, 3) |> PGA3.point_coordinates() |> IO.inspect()
PGA3.origin() |> PGA3.point_coordinates() |> IO.inspect()

PGA3.dual(PGA3.new(scalar: 1)) |> IO.inspect()
