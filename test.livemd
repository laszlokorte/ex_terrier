```elixir
eye = PGA3.point(1, 1, 1)
target = PGA3.point(0, 0, 0)
pole = PGA3.ideal_point(0, 0, 1)

camera = Utils.look_at(eye, target, pole)

trans = fn m, o ->
  PGA3.gp(PGA3.gp(m, o), PGA3.reverse(m))
end

camera
|> trans.(eye)
|> IO.inspect(label: "eye'")

t = PGA3.translator(-1, -1, -1)

t |> trans.(PGA3.point(0, 0, 0)) |> PGA3.point_coordinates()
```

```elixir
m =
  Utils.align(
    [PGA3.dual(PGA3.new(e0: 1))],
    [PGA3.point(1,1,1)]
  )

trans.(m, PGA3.point(0,0,0))
```

```elixir
m =
  Utils.align(
    [
      PGA3.dual(PGA3.new(e0: 1)),
      PGA3.negate(PGA3.dual(PGA3.new(e3: 1)))
    ],
    [
      PGA3.point(1,1,1),
      PGA3.point(0,0,0)
    ]
  )

IO.inspect(trans.(m, PGA3.point(1,1,1)), label: "eye")
IO.inspect(trans.(m, PGA3.point(0,0,0)), label: "target")
```

```elixir
eye = PGA3.point(4, 4, 0)
target = PGA3.point(0, 0, 0)
pole = PGA3.ideal_point(0, 1, 0)

camera = Utils.look_at(eye, target, pole)

Kino.HTML.new("""
  <svg viewBox="-100 -100 200 200" width="100" height="100" preserveAspectRatio="xMidYMid slice">

    #{for {{color, p}, i} <- pyramid_points |> Enum.with_index() do
  camera_point = PGA3.transform(camera, p)
  IO.inspect(PGA3.point_coordinates(camera_point), label: color)
  {x, y, z} = PGA3.point_coordinates(camera_point)
  screen_x = x * 10
  screen_y = -y * 10
  """
    <circle fill="#{color}" r="2" cx="#{screen_x}" cy="#{screen_y}"></circle>
    <text r="2" x="#{screen_x}" y="#{screen_y}" font-size="6">#{i}</text>
  """
end |> Enum.join("\n")}
  </svg>

  <style>
    svg {
      border: 2px solid #aaa;
      width: 100%;
      height: auto;
      box-sizing: border-box;
    }
  </style>
""")
```

