```elixir
defmodule Split do
  import Galixir.Algebras.CGA2

  def split(%CGA2{} = b) do
    b2 = scalar_part(gp(b, b))

    if b2 == 0 do
      raise ArgumentError, "cannot split null bivector"
    end

    b_bar =
      scale(b, 1 / :math.sqrt(abs(b2)))

    p =
      add(
        new(scalar: 1),
        b_bar
      )

    p_tilde =
      sub(
        new(scalar: 1),
        b_bar
      )

    v =
      left_contraction(
        b,
        new(em: 1)
      )

    p1 =
      gp(p, v)

    p2 =
      gp(p_tilde, v)

    {
      p1,
      p2
    }
  end
end

p1 = CGA2.point(-2, 0) |> IO.inspect(label: "p1")
p2 = CGA2.point(2, 0) |> IO.inspect(label: "p1")
#  -2e_1+1.5e_p+2.5e_m

c1 =
  CGA2.circle(p1, 4)
  # -2.5e12p -3.5e12m + 2.0e2pm
  # -2.5e_12p-3.5e_12m-2e_2mp
  |> IO.inspect(label: "c1")

c2 =
  CGA2.circle(p2, 4)
  # -4e_12p-5e_12m+e_2pm
  |> IO.inspect(label: "c2")

# -2e_12+e_2p+3e_2m
custom_point_pair =
  CGA2.point(1, 1)
  |> CGA2.wedge(CGA2.point(1, -1))
  |> IO.inspect(label: "custom point pair")

# p1 -2e_1+1.5e_p+2.5e_m 
#  p2 2e_1+1.5e_p+2.5e_m 
#  c1 -2.5e_12p-p.5e_12m-2e_2pm 
#  c2 -2.5e_12p-p.5e_12m+2e_2pm 
#  pointpair -10e_2m-14e_2p

p =
  CGA2.dual(
    CGA2.wedge(
      CGA2.dual(c1),
      CGA2.dual(c2)
    )
  )
  |> IO.inspect(label: "point_pair")
  |> Split.split()
  |> IO.inspect(label: "split point pair")
  |> elem(0)

custom_point_pair
|> Split.split()
|> elem(0)
|> CGA2.point_coordinates()
|> IO.inspect(label: "custom_1 coord")

p |> CGA2.point_coordinates() |> IO.inspect(label: "p_1 coord")

IO.inspect(p, label: "p")
IO.inspect(CGA2.dot(p, p), label: "P·P")

IO.inspect(CGA2.dot(p, CGA2.e_inf()), label: "P·e∞")
IO.inspect(CGA2.dot(p, CGA2.e_o()), label: "P·eo")
```

